<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_service_record_tree" model="ir.ui.view">
        <field name="name">fleet.service.record.tree</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_date"/>
                <field name="service_type"/>
                <field name="cost"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_fleet_service_record_form" model="ir.ui.view">
        <field name="name">fleet.service.record.form</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <form string="Fleet Service Record">
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary" states="draft"/>
                    <button name="action_done" type="object" string="Mark Done" class="btn-success" states="in_progress"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" states="draft,in_progress"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" states="cancelled"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="vehicle_id"/>
                            <field name="technician_id"/>
                            <field name="service_date"/>
                        </group>
                        <group>
                            <field name="service_type"/>
                            <field name="cost"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Service Lines">
                            <field name="service_line_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Internal Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_fleet_service_record_search" model="ir.ui.view">
        <field name="name">fleet.service.record.search</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_type"/>
                <field name="state"/>
                <filter string="Draft" name="state_draft" domain="[('state', '=', 'draft')]"/>
                <filter string="In Progress" name="state_in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Done" name="state_done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="state_cancelled" domain="[('state', '=', 'cancelled')]"/>
            </search>
        </field>
    </record>

    <record id="action_fleet_service_record" model="ir.actions.act_window">
        <field name="name">Service Records</field>
        <field name="res_model">fleet.service.record</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
