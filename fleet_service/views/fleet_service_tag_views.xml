<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_service_tag_tree" model="ir.ui.view">
        <field name="name">fleet.service.tag.tree</field>
        <field name="model">fleet.service.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>

    <record id="view_fleet_service_tag_form" model="ir.ui.view">
        <field name="name">fleet.service.tag.form</field>
        <field name="model">fleet.service.tag</field>
        <field name="arch" type="xml">
            <form string="Service Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_service_tag" model="ir.actions.act_window">
        <field name="name">Service Tags</field>
        <field name="res_model">fleet.service.tag</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
