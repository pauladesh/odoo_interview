<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_service_record_list" model="ir.ui.view">
        <field name="name">fleet.service.record.list</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <tree decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'done'"
                  decoration-warning="is_expensive and state not in ['done', 'cancelled']">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_date"/>
                <field name="service_type"/>
                <field name="cost"/>
                <field name="is_expensive"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_fleet_service_record_kanban" model="ir.ui.view">
        <field name="name">fleet.service.record.kanban</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="cost"/>
                <field name="currency_id"/>
                <field name="state"/>
                <field name="tag_ids"/>
                <field name="color"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record oe_kanban_color_#{record.color.raw_value}">
                            <div class="o_kanban_record_top">
                                <strong><field name="name"/></strong>
                                <span class="badge rounded-pill bg-secondary float-end"><field name="state"/></span>
                            </div>
                            <div class="mt8">
                                <div><field name="vehicle_id"/></div>
                                <div><field name="service_type"/></div>
                                <div><field name="cost" widget="monetary" options="{'currency_field': 'currency_id'}"/></div>
                                <div class="mt8"><field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_fleet_service_record_form" model="ir.ui.view">
        <field name="name">fleet.service.record.form</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <form string="Fleet Service Record">
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary" states="draft"/>
                    <button name="action_done" type="object" string="Done" class="btn-success" states="in_progress"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary" states="draft,in_progress"/>
                    <button name="action_reset_draft" type="object" string="Reset" states="cancelled"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_view_vehicle_services" class="oe_stat_button" icon="fa-wrench">
                            <field name="vehicle_service_count" string="Vehicle Services" widget="statinfo"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="vehicle_id"/>
                            <field name="technician_id"/>
                            <field name="service_date"/>
                        </group>
                        <group>
                            <field name="service_type"/>
                            <field name="cost"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Service Lines">
                            <field name="service_line_ids">
                                <tree editable="bottom">
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="unit_price"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes &amp; Info">
                            <group>
                                <field name="notes"/>
                            </group>
                            <group>
                                <field name="is_expensive" readonly="1"/>
                                <field name="duration_days" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_fleet_service_record_search" model="ir.ui.view">
        <field name="name">fleet.service.record.search</field>
        <field name="model">fleet.service.record</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="technician_id"/>
                <field name="service_type"/>
                <field name="state"/>

                <filter string="Done Services" name="done_services" domain="[('state', '=', 'done')]"/>
                <filter string="Expensive" name="expensive_services" domain="[('is_expensive', '=', True)]"/>
                <filter string="My Services" name="my_services" domain="[('technician_id', '=', uid)]"/>
                <filter string="This Month" name="this_month" domain="[('service_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d')), ('service_date', '&lt;', (context_today().replace(day=1) + relativedelta(months=1)).strftime('%Y-%m-%d'))]"/>

                <group expand="0" string="Group By">
                    <filter string="Service Type" name="group_by_service_type" context="{'group_by': 'service_type'}"/>
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Technician" name="group_by_technician" context="{'group_by': 'technician_id'}"/>
                    <filter string="Vehicle" name="group_by_vehicle" context="{'group_by': 'vehicle_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fleet_service_record" model="ir.actions.act_window">
        <field name="name">Service Records</field>
        <field name="res_model">fleet.service.record</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{'search_default_group_by_state': 1, 'group_by': 'state'}</field>
        <field name="search_view_id" ref="view_fleet_service_record_search"/>
    </record>

    <record id="view_fleet_service_tag_tree" model="ir.ui.view">
        <field name="name">fleet.service.tag.tree</field>
        <field name="model">fleet.service.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>

    <record id="view_fleet_service_tag_form" model="ir.ui.view">
        <field name="name">fleet.service.tag.form</field>
        <field name="model">fleet.service.tag</field>
        <field name="arch" type="xml">
            <form string="Service Tag">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color_picker"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_service_tag" model="ir.actions.act_window">
        <field name="name">Service Tags</field>
        <field name="res_model">fleet.service.tag</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
